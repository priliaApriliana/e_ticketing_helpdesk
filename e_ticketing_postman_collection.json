{
	"info": {
		"name": "E-Ticketing Helpdesk API",
		"description": "Koleksi API untuk sistem bantuan e-ticketing.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@gmail.com\",\n    \"password\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@gmail.com\",\n    \"password\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Tickets",
			"item": [
				{
					"name": "List Tickets",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tickets",
							"host": ["{{baseUrl}}"],
							"path": ["tickets"]
						}
					}
				},
				{
					"name": "Create Ticket",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Masalah Jaringan\",\n    \"description\": \"WiFi di lantai 3 sering terputus\",\n    \"priority\": \"high\",\n    \"category\": \"Network\",\n    \"created_by\": \"isi-uuid-user-disini\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/tickets",
							"host": ["{{baseUrl}}"],
							"path": ["tickets"]
						}
					}
				},
				{
					"name": "Update Status / Assign",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"in_progress\",\n    \"assigned_to\": \"isi-uuid-teknisi-disini\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/tickets/{{ticketId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "{{ticketId}}", "status"]
						}
					}
				}
			]
		},
		{
			"name": "Comments",
			"item": [
				{
					"name": "Get Comments",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tickets/{{ticketId}}/comments",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "{{ticketId}}", "comments"]
						}
					}
				},
				{
					"name": "Add Comment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"isi-uuid-user\",\n    \"content\": \"Mohon segera diperiksa ya teknisi.\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/tickets/{{ticketId}}/comments",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "{{ticketId}}", "comments"]
						}
					}
				}
			]
		},
		{
			"name": "Dashboard & Users",
			"item": [
				{
					"name": "Metrics",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/dashboard/metrics",
							"host": ["{{baseUrl}}"],
							"path": ["dashboard", "metrics"]
						}
					}
				},
				{
					"name": "List Technical Support",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users?role=technical_support",
							"host": ["{{baseUrl}}"],
							"path": ["users"],
							"query": [
								{
									"key": "role",
									"value": "technical_support"
								}
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api"
		},
		{
			"key": "token",
			"value": "paste-token-jwt-disini"
		},
		{
			"key": "ticketId",
			"value": "isi-id-tiket-untuk-test"
		}
	]
}
